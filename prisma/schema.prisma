generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String?   @db.Text
  name            String?
  phone           String?
  avatar          String?
  role            Role      @default(CUSTOMER)
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  reviews   Review[]
  addresses Address[]

  @@map("profiles")
}

model MediaAsset {
  id         String   @id @default(cuid())
  url        String   @unique
  filename   String?
  mimeType   String?  @map("mime_type")
  sizeBytes  Int?     @map("size_bytes")
  width      Int?
  height     Int?
  kind       String   @default("image") // 'image' | 'video'
  source     String   @default("upload") // 'upload' | 'backfill' | 'external'
  uploadedBy String?  @map("uploaded_by")
  alt        String?
  tags       String[] @default([])
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([kind])
  @@index([createdAt])
  @@map("media_assets")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  icon      String?
  image     String?
  color     String    @default("#16A34A")
  seoIntro  String?   @db.Text @map("seo_intro")
  products         Product[]
  categoryMappings CategoryMapping[]

  @@map("categories")
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  contactName String?   @map("contact_name")
  email       String?
  phone       String?
  address     String?
  notes       String?   @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@map("suppliers")
}

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String   @db.Text
  price             Float
  salePrice           Float?    @map("sale_price")
  salePriceExpiresAt DateTime? @map("sale_price_expires_at")
  costPrice         Float?   @map("cost_price")
  stock             Int      @default(0)
  lowStockThreshold Int      @default(10) @map("low_stock_threshold")
  images            String[]
  categoryId        String   @map("category_id")
  supplierId        String?  @map("supplier_id")
  tags              String[]
  isActive          Boolean  @default(true) @map("is_active")
  isFeatured        Boolean  @default(false) @map("is_featured")
  isNew             Boolean  @default(false) @map("is_new")
  isTaxable         Boolean  @default(true) @map("is_taxable")
  trackInventory    Boolean  @default(true) @map("track_inventory")
  brand             String?
  sku               String?  @unique
  barcode           String?
  weight            Float?   // kilograms
  length            Float?   // centimetres — for carrier package sizing
  width             Float?   // centimetres
  height            Float?   // centimetres
  videoUrl          String?  @map("video_url")
  aiFaqJson         Json?    @map("ai_faq_json")   // [{ q, a }, ...] — Gemini-generated FAQ
  aiDescAt          DateTime? @map("ai_desc_at")   // last time AI rewrote description
  aiFaqAt           DateTime? @map("ai_faq_at")    // last time AI generated FAQ
  kind                ProductKind @default(PHYSICAL)
  digitalDeliveryNote String?     @db.Text @map("digital_delivery_note")
  planId              String?     @map("plan_id")
  boughtTogetherIds String[] @default([]) @map("bought_together_ids")
  viewCount         Int      @default(0) @map("view_count")
  rating            Float    @default(0)
  reviewCount       Int      @default(0) @map("review_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  category       Category        @relation(fields: [categoryId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  reviews        Review[]
  inventoryLogs  InventoryLog[]
  options        ProductOption[]
  variants       ProductVariant[]

  @@map("products")
}

model ProductOption {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  name      String
  position  Int      @default(0)
  values    String[]

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_options")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  title     String
  sku       String?  @unique
  price     Float?
  stock     Int      @default(0)
  image     String?
  options   Json
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

model InventoryLog {
  id          String        @id @default(cuid())
  productId   String        @map("product_id")
  type        InventoryType
  quantity    Int
  stockAfter  Int           @map("stock_after")
  note        String?
  referenceId String?       @map("reference_id")
  createdAt   DateTime      @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("inventory_logs")
}

enum InventoryType {
  PURCHASE    // Received from supplier — stock in
  SALE        // Deducted by order — stock out
  ADJUSTMENT  // Manual correction
  RETURN      // Customer return — stock in
  DAMAGE      // Written off — stock out
}

model Order {
  id             String        @id @default(cuid())
  userId         String?       @map("user_id")
  status         OrderStatus   @default(PENDING)
  total          Float
  subtotal       Float
  deliveryCharge Float         @default(0) @map("delivery_charge")
  name           String
  phone          String
  email          String?
  address        String
  house          String?
  road           String?
  city           String        @default("Kathmandu")
  lat            Float?
  lng            Float?
  paymentMethod  PaymentMethod @map("payment_method")
  paymentStatus  PaymentStatus @default(UNPAID) @map("payment_status")
  transactionId  String?       @map("transaction_id")
  advancePaid    Float?        @map("advance_paid")
  codAmount      Float?        @map("cod_amount")
  advanceMethod  String?       @map("advance_method")    // 'ESEWA' | 'KHALTI'
  pathaoOrderId  String?       @map("pathao_order_id")
  pathaoHash     String?       @map("pathao_hash")
  trackingUrl    String?       @map("tracking_url")
  shippingOption   String?  @map("shipping_option")
  shippingProvider String?  @map("shipping_provider")
  source         String        @default("ONLINE") // ONLINE | POS
  couponCode     String?       @map("coupon_code")
  couponDiscount Float?        @map("coupon_discount")
  autoDiscount   Float?        @map("auto_discount")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // userId stored for reference — no FK relation so guest orders (null) and
  // deleted-profile orders don't break
  items OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  price     Float
  name      String
  image     String?

  order Order @relation(fields: [orderId], references: [id])
  // productId is stored for reference but has no FK constraint —
  // orders must survive product edits/deletions

  @@map("order_items")
}

model Review {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user    Profile @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("reviews")
}

model Address {
  id        String  @id @default(cuid())
  userId    String  @map("user_id")
  label     String  @default("Home")
  name      String
  phone     String
  address   String
  house     String?
  road      String?
  city      String  @default("Kathmandu")
  lat       Float?
  lng       Float?
  isDefault Boolean @default(false) @map("is_default")

  // Structured Nepal address fields — nullable for back-compat with addresses
  // created before this migration. New addresses captured via NepalAddressSelector
  // populate these so saved addresses round-trip cleanly back into the picker.
  province     String?
  district     String?
  municipality String?
  ward         String?
  street       String?
  tole         String?

  user Profile @relation(fields: [userId], references: [id])

  @@map("addresses")
}

model PathaoToken {
  id          String   @id @default(cuid())
  accessToken String   @db.Text @map("access_token")
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("pathao_tokens")
}

model CategoryMapping {
  id             String   @id @default(cuid())
  source         String                          // "daraz" | "amazon" | etc.
  externalName   String   @map("external_name") // "Home Decor"
  externalId     String?  @map("external_id")   // "10000426"
  categoryId     String   @map("category_id")
  category       Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now()) @map("created_at")

  @@unique([source, externalName])
  @@map("category_mappings")
}

model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model LogisticsSettings {
  id           String   @id @default(cuid())
  provider     String   @unique  // 'PATHAO' | 'PICKNDROP'
  isActive     Boolean  @default(true)  @map("is_active")
  isMock       Boolean  @default(true)  @map("is_mock")

  // Auth credentials
  clientId     String?  @map("client_id")
  clientSecret String?  @map("client_secret") @db.Text
  apiKey       String?  @map("api_key")
  apiSecret    String?  @map("api_secret") @db.Text

  // Store / pickup details
  storeId      String?  @map("store_id")
  storeName    String?  @map("store_name")
  storePhone   String?  @map("store_phone")
  storeAddress String?  @map("store_address")
  storeLat     Float?   @map("store_lat")
  storeLng     Float?   @map("store_lng")

  // Pick & Drop pickup defaults — used as `pickup_branch`/`city_area`/`location` on rate + create_order calls
  pickupBranch   String? @map("pickup_branch")
  pickupArea     String? @map("pickup_area")
  pickupLocation String? @map("pickup_location")

  // Cap on surge price passed through to customer (NPR). null/0 = no cap.
  maxSurgeNpr    Float?  @map("max_surge_npr")

  // Base URL override
  baseUrl      String?  @map("base_url")

  notes        String?  @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("logistics_settings")
}

model Expense {
  id          String   @id @default(cuid())
  amount      Float
  category    String   // RENT | SALARY | SUPPLIER | UTILITIES | MARKETING | TRANSPORT | OTHER
  description String?  @db.Text
  paidTo      String?  @map("paid_to")
  supplierId  String?  @map("supplier_id")
  date        DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("expenses")
}

model Conversation {
  id            String    @id @default(cuid())
  platform      String    // WHATSAPP | MESSENGER
  customerId    String    @map("customer_id")
  customerName  String?   @map("customer_name")
  customerPhone String?   @map("customer_phone")
  status        String    @default("OPEN")       // OPEN | CLOSED
  lastMessageAt DateTime? @map("last_message_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  messages      Message[]
  @@unique([platform, customerId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  direction      String       // IN | OUT
  content        String       @db.Text
  externalId     String?      @map("external_id")
  status         String       @default("SENT")  // SENT | DELIVERED | READ | FAILED
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  @@map("messages")
}

model NotificationLog {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  type      String   // ORDER_CONFIRMED | ORDER_SHIPPED | ORDER_DELIVERED | ABANDONED_CART
  phone     String
  status    String   // SENT | FAILED
  error     String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("notification_logs")
}

model CartAbandonment {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  cartJson  String   @db.Text @map("cart_json")
  reminded  Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("cart_abandonments")
}

// Customer-asked questions on a product
model ProductQuestion {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  userId     String?  @map("user_id")           // null = guest
  authorName String   @map("author_name")
  body       String   @db.Text
  isApproved Boolean  @default(true) @map("is_approved")
  createdAt  DateTime @default(now()) @map("created_at")

  answers ProductAnswer[]

  @@index([productId, createdAt])
  @@map("product_questions")
}

// Answers to a product question — usually from staff, sometimes other customers
model ProductAnswer {
  id         String   @id @default(cuid())
  questionId String   @map("question_id")
  userId     String?  @map("user_id")           // null = system/anonymous
  authorName String   @map("author_name")
  body       String   @db.Text
  isOfficial Boolean  @default(false) @map("is_official")  // true = answered by store
  createdAt  DateTime @default(now()) @map("created_at")

  question ProductQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId, createdAt])
  @@map("product_answers")
}

// Customer wishlist
model WishlistItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, productId])
  @@index([userId])
  @@map("wishlist_items")
}

// FCM push notification tokens for the Flutter mobile app
model DeviceToken {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")        // null = guest device
  token     String   @unique                 // FCM registration token
  platform  String   @default("android")    // android | ios
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("device_tokens")
}

model Coupon {
  id          String     @id @default(cuid())
  code        String     @unique
  type        CouponType
  value       Float
  minOrder    Float?     @map("min_order")
  maxUses     Int?       @map("max_uses")
  usedCount   Int        @default(0) @map("used_count")
  expiresAt   DateTime?  @map("expires_at")
  isActive    Boolean    @default(true) @map("is_active")
  scope       String     @default("ALL")  // ALL | CATEGORY | PRODUCT
  categoryIds String[]   @default([]) @map("category_ids")
  productIds  String[]   @default([]) @map("product_ids")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@map("coupons")
}

enum CouponType {
  PERCENT
  FIXED
}

model GiftCard {
  id              String   @id @default(cuid())
  code            String   @unique
  initialValue    Float    @map("initial_value")  // What it was issued for
  balance         Float                            // Current remaining (drops on redemption)
  expiresAt       DateTime? @map("expires_at")
  isActive        Boolean  @default(true) @map("is_active")
  issuedToEmail   String?  @map("issued_to_email")
  issuedToUserId  String?  @map("issued_to_user_id")
  note            String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  redemptions     GiftCardRedemption[]

  @@map("gift_cards")
}

model GiftCardRedemption {
  id          String   @id @default(cuid())
  giftCardId  String   @map("gift_card_id")
  orderId     String   @map("order_id")
  amount      Float
  redeemedAt  DateTime @default(now()) @map("redeemed_at")

  giftCard    GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
  @@index([orderId])
  @@map("gift_card_redemptions")
}

enum Role {
  CUSTOMER  // Shoppers — account, orders, wishlist
  STAFF     // View/update orders, customer support only
  MANAGER   // Products + orders + customers + analytics
  ADMIN     // Full access including settings & logistics
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  COD
  PARTIAL_COD
  ESEWA
  KHALTI
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum ProductKind {
  PHYSICAL
  DIGITAL
  SUBSCRIPTION
}

model Plan {
  id            String       @id @default(cuid())
  name          String
  description   String?      @db.Text
  amount        Float
  interval      PlanInterval
  intervalCount Int          @default(1) @map("interval_count")
  trialDays     Int          @default(0) @map("trial_days")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("plans")
}

enum PlanInterval {
  WEEKLY
  MONTHLY
  YEARLY
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @map("user_id")
  planId             String             @map("plan_id")
  status             SubscriptionStatus @default(ACTIVE)
  startedAt          DateTime           @default(now()) @map("started_at")
  trialEndsAt        DateTime?          @map("trial_ends_at")
  currentPeriodStart DateTime           @map("current_period_start")
  currentPeriodEnd   DateTime           @map("current_period_end")
  cancelAtPeriodEnd  Boolean            @default(false) @map("cancel_at_period_end")
  cancelledAt        DateTime?          @map("cancelled_at")
  notes              String?            @db.Text
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  plan     Plan      @relation(fields: [planId], references: [id])
  invoices Invoice[]

  @@index([userId])
  @@index([status])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
  TRIALING
}

model Invoice {
  id             String        @id @default(cuid())
  subscriptionId String?       @map("subscription_id")
  userId         String        @map("user_id")
  number         String        @unique
  amount         Float
  status         InvoiceStatus @default(OPEN)
  dueDate        DateTime      @map("due_date")
  paidAt         DateTime?     @map("paid_at")
  paymentMethod  String?       @map("payment_method")
  transactionId  String?       @map("transaction_id")
  notes          String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("invoices")
}

enum InvoiceStatus {
  OPEN
  PAID
  OVERDUE
  VOID
}
